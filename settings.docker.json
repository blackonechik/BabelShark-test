{
  "mysql": {
    "host": "mysql",
    "port": 3306,
    "user": "meteor",
    "password": "meteor",
    "database": "babelshark_test",
    "serverId": 1
  },
  "demo": {
    "autoChanges": {
      "enabled": true,
      "intervalMs": 4000
